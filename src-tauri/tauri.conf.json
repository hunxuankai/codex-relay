{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Relay",
  "mainBinaryName": "CodexRelay",
  "version": "0.1.0",
  "identifier": "com.codexrelay.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Relay",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost https://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "shortDescription": "Safely manage local Codex providers on Windows",
    "longDescription": "Codex Relay manages Codex provider configuration, local API keys, backups, health checks, tray switching, and autostart for the current Windows user.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "template": "installer/custom-installer.nsi",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "startMenuFolder": "Codex Relay",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
